OPENAI_API_KEY=sk-...

# Models — see https://developers.openai.com/api/docs/models/gpt-5.5
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe

# MCP server
MCP_HOST=127.0.0.1
MCP_PORT=9000
MCP_PATH=/mcp

# Chat backend
CHAT_HOST=127.0.0.1
CHAT_PORT=8000
PHARMA_DB=./data/pharma.db
RAG_DOCS_DIR=./data/docs
